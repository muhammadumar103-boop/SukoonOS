generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
  VOLUNTEER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  REVIEW
  CLOSING
  COMPLETED
  PAUSED
}

enum DonationStatus {
  PLEDGED
  PROCESSING
  RECEIVED
  REFUNDED
  CANCELLED
}

enum DonorType {
  INDIVIDUAL
  CORPORATE
  FOUNDATION
  COMMUNITY
}

enum DonorHealth {
  NEW
  STRONG
  WATCH
  AT_RISK
}

enum ExpenseStatus {
  DRAFT
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum TransferStatus {
  DRAFT
  REVIEW
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ReportStatus {
  DRAFT
  REVIEW
  READY
  ARCHIVED
}

enum ActivityType {
  AUTH
  PROJECT
  DONATION
  DONOR
  EXPENSE
  TRANSFER
  REPORT
  SETTING
  TASK
}

model UserProfile {
  id          String        @id @default(cuid())
  authUserId  String        @unique
  email       String        @unique
  fullName    String
  role        UserRole      @default(VOLUNTEER)
  title       String?
  avatarUrl   String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  activities  ActivityLog[]
  assignedTasks Task[]

  @@index([role])
  @@index([isActive])
}

model Donor {
  id          String         @id @default(cuid())
  name        String
  type        DonorType      @default(INDIVIDUAL)
  health      DonorHealth    @default(NEW)
  email       String?
  phone       String?
  contactName String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  donations   Donation[]

  @@index([name])
  @@index([type])
  @@index([health])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  leadName    String
  budgetCents Int           @default(0)
  spentCents  Int           @default(0)
  progress    Int           @default(0)
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  donations   Donation[]
  expenses    Expense[]
  tasks       Task[]

  @@index([status])
  @@index([leadName])
}

model Donation {
  id          String         @id @default(cuid())
  donorId     String
  projectId   String?
  amountCents Int
  method      String
  fund        String
  status      DonationStatus @default(PROCESSING)
  receivedAt  DateTime       @default(now())
  receiptCode String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  donor       Donor          @relation(fields: [donorId], references: [id], onDelete: Restrict)
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([donorId])
  @@index([projectId])
  @@index([status])
  @@index([receivedAt])
}

model Expense {
  id          String        @id @default(cuid())
  projectId   String?
  vendor      String
  category    String
  amountCents Int
  status      ExpenseStatus @default(PENDING)
  submittedAt DateTime      @default(now())
  approvedAt  DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([submittedAt])
}

model BankAccount {
  id           String     @id @default(cuid())
  name         String
  institution  String
  currency     String     @default("USD")
  balanceCents Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  outgoingTransfers Transfer[] @relation("TransferFromAccount")
  incomingTransfers Transfer[] @relation("TransferToAccount")

  @@index([isActive])
}

model Transfer {
  id            String         @id @default(cuid())
  fromAccountId String
  toAccountId   String
  amountCents   Int
  status        TransferStatus @default(REVIEW)
  scheduledFor  DateTime?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fromAccount   BankAccount    @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount     BankAccount    @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([status])
  @@index([scheduledFor])
}

model Report {
  id          String       @id @default(cuid())
  name        String
  owner       String
  description String?
  status      ReportStatus @default(DRAFT)
  periodStart DateTime?
  periodEnd   DateTime?
  payload     Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([owner])
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  value       Json
  isSecret    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([isSecret])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  priority    String       @default("Medium")
  dueDate     DateTime?
  completedAt DateTime?
  projectId   String?
  assigneeId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee    UserProfile? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([dueDate])
  @@index([completedAt])
  @@index([assigneeId])
}

model ActivityLog {
  id        String       @id @default(cuid())
  type      ActivityType
  action    String
  message   String
  metadata  Json?
  actorId   String?
  createdAt DateTime     @default(now())
  actor     UserProfile?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([actorId])
  @@index([createdAt])
}
